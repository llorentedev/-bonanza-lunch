<section id="contacto" class="py-24 lg:py-32 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-green text-sm tracking-widest uppercase font-medium">Empresas</span>
      <h2 class="text-4xl lg:text-5xl font-heading font-bold text-charcoal mt-3 mb-4">
        Soluciones Gastronómicas <span class="text-green">Corporativas</span>
      </h2>
      <p class="text-charcoal/60 max-w-2xl mx-auto">En Bonanza Lunch entendemos el ritmo empresarial. Ofrecemos planes de almuerzo personalizados para oficinas, con menús variados, facturación formal y logística dedicada. Pedí tu cotización hoy mismo.</p>
    </div>

    <div class="grid lg:grid-cols-5 gap-10 lg:gap-16 max-w-5xl mx-auto">
      <div class="lg:col-span-3">
        <form id="reservationForm" class="bg-white rounded-2xl p-8 shadow-md space-y-5">
          <div class="grid sm:grid-cols-2 gap-5">
            <input type="text" placeholder="Nombre completo" required class="w-full px-4 py-3.5 rounded-xl border border-charcoal/15 bg-cream/50 focus:border-green focus:ring-2 focus:ring-green/20 outline-none transition-all duration-300 text-sm placeholder:text-charcoal/60" />
            <input type="email" placeholder="Email" required class="w-full px-4 py-3.5 rounded-xl border border-charcoal/15 bg-cream/50 focus:border-green focus:ring-2 focus:ring-green/20 outline-none transition-all duration-300 text-sm placeholder:text-charcoal/60" />
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <input type="tel" placeholder="Teléfono" required class="w-full px-4 py-3.5 rounded-xl border border-charcoal/15 bg-cream/50 focus:border-green focus:ring-2 focus:ring-green/20 outline-none transition-all duration-300 text-sm placeholder:text-charcoal/60" />
            <select required class="w-full px-4 py-3.5 rounded-xl border border-charcoal/15 bg-cream/50 focus:border-green focus:ring-2 focus:ring-green/20 outline-none transition-all duration-300 text-sm text-charcoal/60">
              <option value="" disabled selected>Comensales</option>
              <option value="1">1 persona</option>
              <option value="2">2 personas</option>
              <option value="3">3 personas</option>
              <option value="4">4 personas</option>
              <option value="5">5 personas</option>
              <option value="6">6+ personas</option>
            </select>
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <input type="date" required class="w-full px-4 py-3.5 rounded-xl border border-charcoal/15 bg-cream/50 focus:border-green focus:ring-2 focus:ring-green/20 outline-none transition-all duration-300 text-sm text-charcoal/60" />
            <input type="time" required class="w-full px-4 py-3.5 rounded-xl border border-charcoal/15 bg-cream/50 focus:border-green focus:ring-2 focus:ring-green/20 outline-none transition-all duration-300 text-sm text-charcoal/60" />
          </div>
          <textarea placeholder="Comentarios o requisitos especiales (opcional)" rows="4" class="w-full px-4 py-3.5 rounded-xl border border-charcoal/15 bg-cream/50 focus:border-green focus:ring-2 focus:ring-green/20 outline-none transition-all duration-300 text-sm placeholder:text-charcoal/60 resize-none"></textarea>
          <button type="submit" class="w-full bg-green hover:bg-green-dark text-white py-3.5 rounded-xl text-sm font-medium tracking-wider uppercase transition-all duration-300 hover:shadow-lg hover:shadow-green/25 active:scale-[0.98]">
            SOLICITAR PRESUPUESTO
          </button>
        </form>
      </div>

      <div class="lg:col-span-2 space-y-8">
        <div class="bg-white/60 backdrop-blur rounded-2xl p-8 border border-white/80 shadow-sm">
          <h3 class="font-heading font-bold text-charcoal text-xl mb-6">Información</h3>
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-green/10 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4A6B42" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <p class="font-medium text-charcoal text-sm">Dirección</p>
                <p class="text-charcoal/50 text-sm">Calle Principal 123<br/>Colonia Centro, CP 44100</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-green/10 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4A6B42" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
              </div>
              <div>
                <p class="font-medium text-charcoal text-sm">Teléfono</p>
                <p class="text-charcoal/50 text-sm">+52 555 123 4567</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-green/10 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4A6B42" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div>
                <p class="font-medium text-charcoal text-sm">Horario</p>
                <p class="text-charcoal/50 text-sm">Lun - Sáb: 1:00 pm - 11:00 pm<br/>Domingo: 2:00 pm - 10:00 pm</p>
              </div>
            </div>

          </div>
        </div>

        <div class="bg-charcoal rounded-2xl p-8 text-center">
          <p class="text-white/60 text-xs tracking-widest uppercase mb-2">Eventos Especiales</p>
          <p class="text-wood font-heading text-xl font-bold mb-2">¿Una ocasión especial?</p>
          <p class="text-white/50 text-sm mb-4">Consultá por nuestro menú de degustación y eventos privados.</p>
          <a href="tel:+525551234567" class="inline-block text-wood hover:text-beige text-sm font-medium transition-colors">Llamanos →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('reservationForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const btn = this.querySelector('button[type="submit"]');
    const originalText = btn.textContent;
    btn.textContent = '¡Solicitud enviada!';
    btn.classList.remove('bg-green', 'hover:bg-green-dark');
    btn.classList.add('bg-charcoal', 'hover:bg-charcoal');
    setTimeout(() => {
      btn.textContent = originalText;
      btn.classList.remove('bg-charcoal', 'hover:bg-charcoal');
      btn.classList.add('bg-green', 'hover:bg-green-dark');
      this.reset();
    }, 3000);
  });
</script>
